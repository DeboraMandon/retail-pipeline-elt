# =============================================================================
# .gitignore — retail-pipeline-elt
# =============================================================================

# --- Secrets : NE JAMAIS committer -------------------------------------------
.env
*.key
*.pem
kaggle.json

# --- Données brutes : trop lourdes pour Git (fournir le script de téléchargement)
data/
*.csv
*.parquet
*.json.gz

# --- Artefacts Python ---------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
dist/
build/

# --- dbt ----------------------------------------------------------------------
dbt/target/
dbt/dbt_packages/
dbt/logs/

# --- Airflow ------------------------------------------------------------------
airflow/logs/*
!airflow/logs/.gitkeep
airflow/plugins/*
!airflow/plugins/.gitkeep
airflow/plugins/__pycache__/

# --- ML -----------------------------------------------------------------------
ml/models/*.pkl
ml/models/*.joblib

# --- OS / IDE -----------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
dbt/profiles/.user.yml
