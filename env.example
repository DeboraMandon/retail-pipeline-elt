# =============================================================================
# retail-pipeline-elt — variables d'environnement
# IMPORTANT : ne jamais committer ce fichier sur GitHub
# Ajouter .env dans .gitignore immédiatement
# Ce fichier est un template : remplacer les valeurs avant de lancer
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=changeme_strong_password
PIPELINE_DB=pipeline_db
AIRFLOW_DB=airflow_db
METABASE_DB=metabase_db

# --- Airflow ------------------------------------------------------------------
# Fernet key : générer avec la commande suivante (Python) :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=REMPLACER_PAR_UNE_VRAIE_FERNET_KEY

# Secret key pour les sessions web Airflow (chaîne aléatoire quelconque)
AIRFLOW_SECRET_KEY=REMPLACER_PAR_UNE_CHAINE_ALEATOIRE

# Identifiants de l'utilisateur admin Airflow (interface sur localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_airflow_password

# --- Kaggle API ---------------------------------------------------------------
# Obtenir sur https://www.kaggle.com/settings > API > Create New Token
# Le fichier téléchargé s'appelle kaggle.json et contient ces deux valeurs
KAGGLE_USERNAME=ton_username_kaggle
KAGGLE_KEY=ta_cle_api_kaggle

# --- dbt ----------------------------------------------------------------------
# Utilisé dans dbt/profiles.yml pour se connecter à PostgreSQL
DBT_DB_HOST=localhost
DBT_DB_PORT=5432
DBT_DB_USER=pipeline_user
DBT_DB_PASSWORD=changeme_strong_password
DBT_DB_NAME=pipeline_db
DBT_SCHEMA=dbt_dev
